{
    "algo_name": "bc",
    "experiment": {
        "name": "bc_rnn",
        "validate": true,
        "logging": {
            "terminal_output_to_txt": true,
            "log_tb": false,
            "log_wandb": false
        },
        "save": {
            "enabled": true,
            "every_n_epochs": 50,
            "on_best_validation": true,
            "on_best_rollout_success_rate": false
        },
        "epoch_every_n_steps": 100,
        "validation_epoch_every_n_steps": 10,
        "render": false,
        "render_video": false,
        "rollout": {
            "enabled": false
        }
    },
    "train": {
        "data": "/home/borys/Desktop/bachalor_thesis_lfd/data/wave/demos.hdf5",
        "output_dir": "/home/borys/Desktop/bachalor_thesis_lfd/models/wave",
        "num_data_workers": 0,
        "hdf5_cache_mode": "all",
        "hdf5_normalize_obs": true,
        "hdf5_filter_key": "train",
        "hdf5_validation_filter_key": "valid",
        "seq_length": 10,
        "pad_seq_length": true,
        "frame_stack": 1,
        "max_grad_norm": 1.0,
        "dataset_keys": ["actions", "rewards", "dones"],
        "action_keys": ["actions"],
        "action_config": {
            "actions": {
                "normalization": "gaussian"
            }
        },
        "cuda": false,
        "batch_size": 32,
        "num_epochs": 500,
        "seed": 1
    },
    "algo": {
        "optim_params": {
            "policy": {
                "optimizer_type": "adam",
                "learning_rate": {
                    "initial": 0.0001,
                    "decay_factor": 0.1,
                    "epoch_schedule": [],
                    "scheduler_type": "multistep"
                },
                "regularization": {
                    "L2": 0.0001
                }
            }
        },
        "loss": {
            "l2_weight": 1.0,
            "l1_weight": 0.0,
            "cos_weight": 0.0
        },
        "actor_layer_dims": [],
        "rnn": {
            "enabled": true,
            "horizon": 10,
            "hidden_dim": 400,
            "rnn_type": "LSTM",
            "num_layers": 2,
            "open_loop": false,
            "kwargs": {
                "bidirectional": false
            }
        },
        "gmm": {
            "enabled": true,
            "num_modes": 5,
            "min_std": 0.0001,
            "std_activation": "softplus",
            "low_noise_eval": true
        },
        "gaussian": {
            "enabled": false
        },
        "vae": {
            "enabled": false
        }
    },
    "observation": {
        "modalities": {
            "obs": {
                "low_dim": [
                    "robot0_eef_pos",
                    "robot0_eef_quat",
                    "robot0_gripper_qpos",
                    "robot0_joint_pos"
                ],
                "rgb": [],
                "depth": [],
                "scan": []
            },
            "goal": {
                "low_dim": [],
                "rgb": []
            }
        },
        "encoder": {
            "low_dim": {
                "core_class": null,
                "core_kwargs": {},
                "obs_randomizer_class": null,
                "obs_randomizer_kwargs": {}
            }
        }
    }
}
